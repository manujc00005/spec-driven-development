{
  "$comment": "macOS/Linux hook-wiring template — the bash counterpart of settings.template.json (which wires the same hooks via PowerShell for Windows). Copy the entries you want into your project's .claude/settings.json. Wires the same hook set as the Windows template, using the .sh variants. Make the scripts executable once: chmod +x hooks/*.sh hooks/lib/claude-json.sh. The .sh hooks are dependency-free (no jq, no python3). Do not wire maven-compile.sh in addition to java-build-test-guard.sh — maven-compile is deprecated and they would compile twice per .java edit.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/git-guardrails.sh",
            "timeout": 5,
            "statusMessage": "Git guardrails check..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/ts-check.sh",
            "timeout": 30,
            "statusMessage": "TypeScript check..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/eslint-fix.sh",
            "timeout": 30,
            "statusMessage": "ESLint fix..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/java-build-test-guard.sh",
            "timeout": 60,
            "statusMessage": "Java build guard..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/prettier-format.sh",
            "timeout": 15,
            "statusMessage": "Prettier format..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/sdd-status-banner.sh",
            "timeout": 5,
            "statusMessage": "SDD status..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/project-init-check.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
